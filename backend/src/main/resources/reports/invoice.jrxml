<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="invoice"
              pageWidth="595"
              pageHeight="842"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="40"
              bottomMargin="40">

    <parameter name="customerName"/>
    <parameter name="companyName"/>
    <parameter name="productName"/>
    <parameter name="totalPrice" class="java.lang.Double"/>

    <background>
        <band height="762">
            <rectangle>
                <reportElement x="0" y="0" width="515" height="762" backcolor="#EEF2FF" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
        </band>
    </background>

    <title>
        <band height="170">

            <rectangle>
                <reportElement x="0" y="0" width="515" height="170" backcolor="#4F46E5" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>

            <ellipse>
                <reportElement x="217" y="18" width="80" height="80" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </ellipse>

            <rectangle radius="3">
                <reportElement x="241" y="36" width="32" height="38" backcolor="#4F46E5" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>

            <rectangle>
                <reportElement x="246" y="46" width="22" height="3" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="246" y="54" width="22" height="3" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="246" y="62" width="14" height="3" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="108" width="515" height="34" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="22" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <text><![CDATA[Invoice Ready]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="142" width="515" height="22" forecolor="#C7D2FE"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="11" pdfFontName="Helvetica"/>
                </textElement>
                <text><![CDATA[Your invoice is available for review]]></text>
            </staticText>

        </band>
    </title>

    <pageHeader>
        <band height="430">

            <rectangle radius="0">
                <reportElement x="0" y="0" width="515" height="430" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>

            <rectangle radius="10">
                <reportElement x="20" y="24" width="80" height="24" backcolor="#EEF2FF" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="20" y="24" width="80" height="24" forecolor="#3730A3"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="10" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <text><![CDATA[Invoice]]></text>
            </staticText>

            <staticText>
                <reportElement x="20" y="62" width="60" height="24" forecolor="#1F2937"/>
                <textElement verticalAlignment="Middle">
                    <font size="13" pdfFontName="Helvetica"/>
                </textElement>
                <text><![CDATA[Dear ]]></text>
            </staticText>
            <textField>
                <reportElement x="72" y="62" width="423" height="24" forecolor="#1F2937"/>
                <textElement verticalAlignment="Middle">
                    <font size="13" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{customerName} + ","]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="96" width="475" height="40" forecolor="#4B5563"/>
                <textElement>
                    <font size="11" pdfFontName="Helvetica"/>
                </textElement>
                <text><![CDATA[Thank you for your order on EuroSupply. Your invoice is ready and attached to this email. Below you can find a summary of your order.]]></text>
            </staticText>

            <rectangle radius="8">
                <reportElement x="20" y="150" width="475" height="190" backcolor="#F9FAFB" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#E5E7EB"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="36" y="166" width="300" height="24" forecolor="#1F2937"/>
                <textElement verticalAlignment="Middle">
                    <font size="13" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <text><![CDATA[Invoice Summary]]></text>
            </staticText>

            <line>
                <reportElement x="36" y="198" width="443" height="1"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#E5E7EB"/></graphicElement>
            </line>

            <staticText>
                <reportElement x="36" y="208" width="180" height="20" forecolor="#6B7280"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" pdfFontName="Helvetica"/>
                </textElement>
                <text><![CDATA[Customer]]></text>
            </staticText>
            <textField>
                <reportElement x="220" y="208" width="259" height="20" forecolor="#1F2937"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{customerName}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="36" y="228" width="443" height="1"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#E5E7EB"/></graphicElement>
            </line>

            <staticText>
                <reportElement x="36" y="238" width="180" height="20" forecolor="#6B7280"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" pdfFontName="Helvetica"/>
                </textElement>
                <text><![CDATA[Company]]></text>
            </staticText>
            <textField>
                <reportElement x="220" y="238" width="259" height="20" forecolor="#1F2937"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{companyName}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="36" y="258" width="443" height="1"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#E5E7EB"/></graphicElement>
            </line>

            <staticText>
                <reportElement x="36" y="268" width="180" height="20" forecolor="#6B7280"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" pdfFontName="Helvetica"/>
                </textElement>
                <text><![CDATA[Product]]></text>
            </staticText>
            <textField>
                <reportElement x="220" y="268" width="259" height="20" forecolor="#1F2937"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{productName}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="36" y="288" width="443" height="1"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#E5E7EB"/></graphicElement>
            </line>

            <staticText>
                <reportElement x="36" y="300" width="180" height="24" forecolor="#4F46E5"/>
                <textElement verticalAlignment="Middle">
                    <font size="12" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <text><![CDATA[Total Amount]]></text>
            </staticText>
            <textField>
                <reportElement x="220" y="300" width="259" height="24" forecolor="#4F46E5"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="12" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <textFieldExpression><![CDATA["€ " + String.format("%.2f", $P{totalPrice})]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="360" width="475" height="50" forecolor="#4B5563"/>
                <textElement>
                    <font size="10" pdfFontName="Helvetica"/>
                </textElement>
                <text><![CDATA[If you have any questions regarding this invoice, feel free to contact our support team at support@eurosupply.com.]]></text>
            </staticText>

        </band>
    </pageHeader>

    <summary>
        <band height="80">

            <rectangle>
                <reportElement x="0" y="0" width="515" height="80" backcolor="#F9FAFB" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#E5E7EB"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="14" width="515" height="22" forecolor="#374151"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="11" isBold="true" pdfFontName="Helvetica-Bold"/>
                </textElement>
                <text><![CDATA[EuroSupply]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="34" width="515" height="16" forecolor="#6B7280"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" pdfFontName="Helvetica"/>
                </textElement>
                <text><![CDATA[Your trusted B2B marketplace]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="56" width="515" height="16" forecolor="#9CA3AF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" pdfFontName="Helvetica"/>
                </textElement>
                <text><![CDATA[© 2026 EuroSupply. All rights reserved.]]></text>
            </staticText>

        </band>
    </summary>

</jasperReport>